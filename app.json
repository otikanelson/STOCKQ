{
  "expo": {
    "name": "Insightory",
    "slug": "stockq",
    "version": "16.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/favicon.png",
    "backgroundColor": "#080B18",
    "scheme": "inventory",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs access to your camera to take photos of products.",
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to select product images.",
        "NSPhotoLibraryAddUsageDescription": "This app needs permission to save photos to your library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#080B18",
        "foregroundImage": "./assets/images/icon.png"
      },
      "package": "com.son_the_nel.Inventory",
      "versionCode": 16,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-blank.png",
          "imageWidth": 1,
          "resizeMode": "contain",
          "dark": {
            "image": "./assets/images/icon.png",
            "backgroundColor": "#080B18"
          },
          "light": {
            "image": "./assets/images/icon_light.png",
            "backgroundColor": "#f0f0f0ff"
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/qurova-light.ttf",
            "./assets/fonts/qurova-regular.ttf",
            "./assets/fonts/qurova-medium.ttf",
            "./assets/fonts/qurova-semibold.ttf",
            "./assets/fonts/qurova-bold.ttf"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "This app needs access to your photo library to select product images.",
          "cameraPermission": "This app needs access to your camera to take photos of products."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7ccb323f-ce43-4d57-aaae-d99c8139faa3"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
