{
  "expo": {
    "name": "Insightory",
    "slug": "stockq",
    "version": "4.1.1",
    "orientation": "portrait",
    "icon": "./assets/images/favicon.png",
    "backgroundColor": "#0D1B4B",
    "scheme": "inventory",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs access to your camera to take photos of products.",
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to select product images.",
        "NSPhotoLibraryAddUsageDescription": "This app needs permission to save photos to your library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D1B4B",
        "foregroundImage": "./assets/images/icon.png"
      },
      "package": "com.son_the_nel.Inventory",
      "versionCode": 4,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0D1B4B",
          "dark": {
            "backgroundColor": "#0D1B4B"
          }
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "This app needs access to your photo library to select product images.",
          "cameraPermission": "This app needs access to your camera to take photos of products."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7ccb323f-ce43-4d57-aaae-d99c8139faa3"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "neil2022"
  }
}
